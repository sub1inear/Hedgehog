---
import { getCollection } from 'astro:content';
import DocsLayout from '../../layouts/DocsLayout.astro';

const docs = await getCollection('docs');
const intro = docs.find(d => d.slug === 'introduction');
if (!intro) throw new Error('Introduction doc not found');
const { Content } = await intro.render();
---
<DocsLayout
  title={intro.data.title}
  description={intro.data.description}
  currentSlug="introduction"
>
  <Content />
</DocsLayout>
