---
import ThemeToggle from './ThemeToggle.astro';
import { BASE } from '../lib/consts';
import { links } from '../lib/nav';
const { pathname } = Astro.url;

// Collect "leaf" paths (more specific nav items) so parent prefix-matches can yield to them.
const leafPaths = new Set(links.map(l => l.href.split('#')[0]));

const active = (href: string) => {
  const path = href.split('#')[0];
  if (pathname === path) return true;
  // If a more specific sibling nav item exactly matches the current path,
  // don't highlight this parent via prefix-match.
  if (path !== '/' && pathname.startsWith(path + '/') && leafPaths.has(pathname)) return false;
  if (path !== '/' && pathname.startsWith(path + '/')) return true;
  return false;
};
---
<header class="sticky top-0 z-40 backdrop-blur-md bg-[color:var(--bg)]/75 border-b border-[var(--border)]">
  <div class="wrap flex h-16 items-center justify-between gap-6">
    <a href={BASE} class="group flex items-center gap-2">
      <!--
        Desktop: invisible slot — the pixel-art hedgehog (HedgehogCursor) sits
        here via fixed positioning and replaces the emoji visually.
        Mobile: show the emoji as usual.
      -->
      <span
        id="hhg-logo-slot"
        class="hidden md:inline-block"
        style="width:48px;height:48px;flex-shrink:0;"
        aria-hidden="true"
      ></span>
      <span class="md:hidden text-2xl" aria-hidden="true">🦔</span>

      <span id="hhg-logo-text" class="font-display text-xl font-bold tracking-tight">
        Hedgehog
      </span>
    </a>

    <div class="flex items-center gap-1">
      <nav class="hidden md:flex items-center gap-1 text-sm">
        {links.map(({ href, label }) => (
          <a
            href={href}
            class:list={[
              'px-3 py-2 rounded-md transition-colors',
              active(href as string)
                ? 'text-[var(--accent)]'
                : 'text-[var(--text-soft)] hover:text-[var(--text)]',
            ]}
          >{label}</a>
        ))}
        <a
          href="https://github.com/sub1inear/Hedgehog"
          class="ml-2 px-3 py-2 rounded-md text-[var(--text-soft)] hover:text-[var(--text)] transition-colors inline-flex items-center gap-1.5"
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 .5C5.65.5.5 5.65.5 12a11.5 11.5 0 0 0 7.86 10.92c.58.1.79-.25.79-.56v-2c-3.2.7-3.88-1.36-3.88-1.36-.53-1.34-1.29-1.7-1.29-1.7-1.05-.72.08-.71.08-.71 1.17.08 1.78 1.2 1.78 1.2 1.03 1.77 2.71 1.26 3.37.96.1-.75.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.28 1.19-3.09-.12-.29-.51-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11.1 11.1 0 0 1 5.79 0c2.2-1.49 3.17-1.18 3.17-1.18.63 1.59.24 2.76.12 3.05.74.81 1.19 1.83 1.19 3.09 0 4.43-2.7 5.4-5.27 5.69.41.36.77 1.06.77 2.13v3.16c0 .31.21.67.79.55A11.5 11.5 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5Z"/>
          </svg>
          GitHub
        </a>
      </nav>
      <ThemeToggle />
      <button
        id="mobile-menu-btn"
        type="button"
        aria-label="Open menu"
        class="md:hidden inline-flex h-9 w-9 items-center justify-center rounded-lg border border-[var(--border)]"
      >
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <path d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="md:hidden hidden border-t border-[var(--border)]">
    <div class="wrap py-3 flex flex-col gap-1 text-sm">
      {links.map(({ href, label }) => (
        <a href={href} class="px-3 py-2 rounded-md text-[var(--text-soft)] hover:text-[var(--text)]">{label}</a>
      ))}
      <a href="https://github.com/sub1inear/Hedgehog" class="px-3 py-2 rounded-md text-[var(--text-soft)] hover:text-[var(--text)]">GitHub</a>
    </div>
  </div>
</header>

<script is:inline>
  (function () {
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    if (btn && menu) btn.addEventListener('click', () => menu.classList.toggle('hidden'));
  })();
</script>
