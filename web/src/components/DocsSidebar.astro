---
import { getCollection } from 'astro:content';
import { BASE } from '../lib/consts';

const docs = (await getCollection('docs')).sort((a, b) => a.data.order - b.data.order);

// Strip the base path (e.g. "/Hedgehog") before extracting the slug
const currentSlug = Astro.url.pathname
  .replace(new RegExp(`^${BASE}`), '')
  .replace(/^\/docs\//, '')
  .replace(/\/$/, '');

// Group by section
const sections = new Map<string, typeof docs>();
for (const doc of docs) {
  const key = doc.data.section;
  if (!sections.has(key)) sections.set(key, [] as any);
  sections.get(key)!.push(doc);
}
---
<nav class="docs-sidebar text-sm">
  <div class="mb-4 pb-4 border-b border-[var(--border)]">
    <a href={`${BASE}/docs`} class="flex items-center gap-2 text-[var(--text-soft)] hover:text-[var(--accent)]">
      <span aria-hidden="true">🦔</span>
      <span class="font-display font-bold">Hedgehog Docs</span>
    </a>
  </div>

  {Array.from(sections.entries()).map(([section, items]) => (
    <div class="mb-6">
      <div class="text-xs uppercase tracking-wider text-[var(--text-muted)] mb-2 px-2">{section}</div>
      <ul class="flex flex-col gap-0.5">
        {items.map(item => {
          const isActive = item.id === currentSlug;
          return (
            <li>
              <a
                href={`${BASE}/docs/${item.id}`}
                class:list={[
                  'block px-2 py-1.5 rounded-md transition-colors',
                  isActive
                    ? 'bg-[var(--accent-soft)] text-[var(--accent)] font-medium'
                    : 'text-[var(--text-soft)] hover:text-[var(--text)] hover:bg-[var(--bg-soft)]',
                ]}
              >{item.data.title}</a>
            </li>
          );
        })}
      </ul>
    </div>
  ))}
</nav>
