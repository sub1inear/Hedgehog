---
// Pixel-art hedgehog companion.
// Sits at the logo slot idle/sleeping until clicked, then follows the cursor.
// Three GIF layers are always loaded (opacity-swap = no reload flicker).
// Reduced-motion / mobile: disabled.
---

<!--
  #hhg-outer   fixed, handles position via translate
  #hhg-inner   handles horizontal flip via scaleX, transform-origin: center
    .hhg-f     each frame layer: position:absolute, opacity toggled
-->
<div
  id="hhg-outer"
  class="hidden md:block"
  style="position:fixed;left:0;top:0;z-index:50;will-change:transform;
         transform:translate(-200px,-200px);opacity:0;pointer-events:none;"
  aria-hidden="true"
>
  <div id="hhg-inner" style="position:relative;width:48px;height:48px;transform-origin:50% 50%;">
    <img id="hhg-f-idle"  src="/hedgehog/idle.gif"  alt="" class="hhg-f" />
    <img id="hhg-f-walk"  src="/hedgehog/move.gif"  alt="" class="hhg-f" />
    <img id="hhg-f-sleep" src="/hedgehog/sleep.gif" alt="" class="hhg-f" />
    <!--
      hhg-f-trans doubles as the pre-click FROZEN state.
      At background-position:0 0 with no animation it shows frame 0 of
      sleep_transition.png — a static standing pose.
    -->
    <div id="hhg-f-trans" class="hhg-f hhg-active"></div>
  </div>
</div>

<style>
  /* All frame layers: stacked, same size, pixel-perfect */
  .hhg-f {
    position: absolute;
    top: 0; left: 0;
    display: block;
    width: 48px;
    height: 48px;
    image-rendering: pixelated;
    image-rendering: -moz-crisp-edges;
    image-rendering: crisp-edges;
    opacity: 0;
    pointer-events: none;
  }
  .hhg-f.hhg-active { opacity: 1; }

  /* Sleep-transition sprite sheet: 5 frames × 48 px = 240 px wide */
  #hhg-f-trans {
    background-image: url('/hedgehog/sleep_transition.png');
    background-size: 240px 48px;
    background-repeat: no-repeat;
    background-position: 0 0;
  }

  /*
    steps(4, end) from 0 → -192px shows frames at 0, -48, -96, -144 during
    playback; fill-mode:forwards then locks on -192 (the 5th / last frame).
    This avoids ending on -240 which would show blank.
  */
  @keyframes hhg-sleep-trans {
    from { background-position: 0 0; }
    to   { background-position: -192px 0; }
  }
</style>

<script is:inline>
(function () {
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
  if (!window.matchMedia('(min-width: 768px)').matches) return;

  const outer    = document.getElementById('hhg-outer');
  const inner    = document.getElementById('hhg-inner');
  const fIdle    = document.getElementById('hhg-f-idle');
  const fWalk    = document.getElementById('hhg-f-walk');
  const fSleep   = document.getElementById('hhg-f-sleep');
  const fTrans   = document.getElementById('hhg-f-trans');
  if (!outer || !inner || !fIdle || !fWalk || !fSleep || !fTrans) return;

  let logoSlot = null;
  let logoText = null;

  // ── Constants ────────────────────────────────────────────────
  const SPEED       = 1.2;   // px / frame
  const STOP_DIST   = 20;    // px radius — stop walking here
  const HALF        = 24;    // half of 48 px sprite
  const SLEEP_AFTER = 5000;  // ms idle before napping
  const TRANS_MS    = 850;   // ms for sleep-transition animation
  // ─────────────────────────────────────────────────────────────

  // STATIC = pre-click frozen pose (frame 0 of sleep_transition.png, no CSS animation)
  const S = { STATIC: 'static', IDLE: 'idle', WALK: 'walk', SLEEP_TRANS: 'sleep_trans', SLEEP: 'sleep' };
  const layers = { idle: fIdle, walk: fWalk, sleep: fSleep, sleep_trans: fTrans };

  let hx = 0, hy = 0;         // hedgehog world centre
  let cx = 0, cy = 0;         // cursor / target centre
  let homeX = 0, homeY = 0;

  let state      = S.STATIC;
  let facingLeft = false;
  let following  = false;
  let idleSince  = Date.now();

  function computeHome() {
    if (logoSlot) {
      const rs = logoSlot.getBoundingClientRect();
      homeX = Math.round(rs.left + rs.width / 2);
      const el = logoText || logoSlot;
      const r  = el.getBoundingClientRect();
      homeY = Math.round(r.top + r.height / 6);
    } else {
      homeX = 40; homeY = 32;
    }
  }

  // ── Layer switching (opacity, no src change = no flicker) ────
  function showLayer(key) {
    for (const [k, el] of Object.entries(layers)) {
      el.classList.toggle('hhg-active', k === key);
    }
  }

  function enterState(next) {
    if (state === next) return;
    state = next;

    if (next === S.STATIC) {
      // Frozen first frame of sleep_transition — no CSS animation, no GIF
      fTrans.style.animation = 'none';
      fTrans.style.backgroundPosition = '0 0';
      showLayer('sleep_trans');

    } else if (next === S.IDLE) {
      fTrans.style.animation = 'none';
      showLayer('idle');
      idleSince = Date.now();

    } else if (next === S.WALK) {
      fTrans.style.animation = 'none';
      showLayer('walk');

    } else if (next === S.SLEEP_TRANS) {
      // Reset sprite sheet to first frame before playing
      fTrans.style.animation = 'none';
      void fTrans.offsetWidth;                     // force reflow
      fTrans.style.backgroundPosition = '0 0';
      showLayer('sleep_trans');
      fTrans.style.animation =
        `hhg-sleep-trans ${TRANS_MS}ms steps(4, end) 1 forwards`;
      fTrans.addEventListener('animationend', () => {
        if (state === S.SLEEP_TRANS) enterState(S.SLEEP);
      }, { once: true });

    } else if (next === S.SLEEP) {
      fTrans.style.animation = 'none';
      showLayer('sleep');
    }
  }

  // ── Cursor tracking (only after click) ───────────────────────
  document.addEventListener('mousemove', (e) => {
    if (!following) return;
    cx = e.clientX;
    cy = e.clientY;
    if (state === S.SLEEP || state === S.SLEEP_TRANS) {
      fTrans.style.animation = 'none';
      enterState(S.IDLE);
    }
  });

  // ── Init: cache header refs (unavailable at parse time) and position ──
  requestAnimationFrame(() => {
    logoSlot = document.getElementById('hhg-logo-slot');
    logoText = document.getElementById('hhg-logo-text');

    // Click activates following via the slot rather than the sprite itself,
    // so the underlying <a href="/"> anchor stays reachable.
    if (logoSlot) {
      logoSlot.addEventListener('click', (e) => {
        if (following) return; // already following — let click reach the anchor
        e.preventDefault();
        following = true;
        outer.style.pointerEvents = 'none';
        enterState(S.IDLE);
      });
    }

    computeHome();
    hx = homeX; hy = homeY;
    cx = homeX; cy = homeY;
    outer.style.opacity = '1';
  });

  // ── Main loop ────────────────────────────────────────────────
  let rafHandle;

  function tick() {
    rafHandle = requestAnimationFrame(tick);

    if (!following) {
      // Track the slot every frame so font-load reflows don't drift the position
      computeHome();
      hx = homeX;
      hy = homeY;
      // Stay frozen (STATIC) — no state machine until the user clicks

    } else {
      const dx   = cx - hx;
      const dy   = cy - hy;
      const dist = Math.sqrt(dx * dx + dy * dy);
      const atCursor = dist <= STOP_DIST;

      // State transitions
      if (state === S.WALK && atCursor) {
        enterState(S.IDLE);
      } else if (state === S.IDLE) {
        if (!atCursor) {
          enterState(S.WALK);
        } else if (Date.now() - idleSince >= SLEEP_AFTER) {
          enterState(S.SLEEP_TRANS);
        }
      }

      // Move
      if (state === S.WALK && !atCursor) {
        const inv = 1 / dist;
        hx += dx * inv * SPEED;
        hy += dy * inv * SPEED;

        const wantsLeft = dx < 0;
        if (wantsLeft !== facingLeft) {
          facingLeft = wantsLeft;
          inner.style.transform = `scaleX(${facingLeft ? -1 : 1})`;
        }
      }
    }

    outer.style.transform = `translate(${hx - HALF}px,${hy - HALF}px)`;
  }

  document.addEventListener('astro:before-swap', () => cancelAnimationFrame(rafHandle), { once: true });

  tick();
})();
</script>
